generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserPlan {
  FREE
  PREMIUM
}

enum SubscriptionStatus {
  PENDING
  APPROVED
  DECLINED
  VOIDED
  ERROR
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

// Perfil de usuario (extiende auth.users de Supabase)
model Profile {
  id                  String    @id @default(uuid())
  userId              String    @unique // UUID de Supabase Auth
  email               String
  fullName            String?
  avatarUrl           String?
  currency            String    @default("COP")
  plan                UserPlan  @default(FREE)
  planActivatedAt     DateTime?
  planExpiresAt       DateTime?
  onboardingCompleted Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relaciones personales
  accounts        Account[]
  categories      Category[]
  transactions    Transaction[]
  budgets         Budget[]
  coachInsights   CoachInsight[]
  subscriptions   Subscription[]
  paymentSources  PaymentSource[]

  // Relaciones de sala compartida
  contactsRequested  Contact[]           @relation("ContactRequests")
  contactsReceived   Contact[]           @relation("ContactReceived")
  sharedSpaces       SpaceMember[]
  spacesCreated      SharedSpace[]       @relation("SpaceCreator")
  sharedTransactions SharedTransaction[]
  pushSubscriptions  PushSubscription[]

  @@map("profiles")
}

// ─── Contactos ────────────────────────────────────────────────────────────────

model Contact {
  id          String        @id @default(uuid())
  requesterId String
  receiverId  String
  status      ContactStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  requester Profile @relation("ContactRequests", fields: [requesterId], references: [userId], onDelete: Cascade)
  receiver  Profile @relation("ContactReceived",  fields: [receiverId],  references: [userId], onDelete: Cascade)

  @@unique([requesterId, receiverId])
  @@index([receiverId])
  @@map("contacts")
}

enum ContactStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// ─── Sala compartida ──────────────────────────────────────────────────────────

enum SpaceType {
  PAREJA
  FAMILIAR
}

model SharedSpace {
  id                  String    @id @default(uuid())
  name                String    @default("Finanzas compartidas")
  type                SpaceType @default(PAREJA)
  createdBy           String
  deletionRequestedBy String?  // userId quien solicitó eliminar la sala
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  creator      Profile             @relation("SpaceCreator", fields: [createdBy], references: [userId], onDelete: Cascade)
  members      SpaceMember[]
  budgets      SharedBudget[]
  transactions SharedTransaction[]

  @@map("shared_spaces")
}

model SpaceMember {
  id       String    @id @default(uuid())
  spaceId  String
  userId   String
  salary   Decimal?  @db.Decimal(12, 2)
  role     SpaceRole @default(MEMBER)
  joinedAt DateTime  @default(now())

  space   SharedSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  profile Profile     @relation(fields: [userId],  references: [userId], onDelete: Cascade)

  @@unique([spaceId, userId])
  @@map("space_members")
}

enum SpaceRole {
  OWNER
  MEMBER
}

model SharedBudget {
  id           String       @id @default(uuid())
  spaceId      String
  categoryName String
  percentage   Decimal      @db.Decimal(5, 2)
  period       BudgetPeriod @default(MONTHLY)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  space        SharedSpace         @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  transactions SharedTransaction[]

  @@map("shared_budgets")
}

model SharedTransaction {
  id             String   @id @default(uuid())
  spaceId        String
  sharedBudgetId String?
  authorId       String
  amount         Decimal  @db.Decimal(12, 2)
  description    String?
  date           DateTime @default(now())
  createdAt      DateTime @default(now())

  space        SharedSpace   @relation(fields: [spaceId],        references: [id], onDelete: Cascade)
  sharedBudget SharedBudget? @relation(fields: [sharedBudgetId], references: [id], onDelete: SetNull)
  author       Profile       @relation(fields: [authorId],       references: [userId], onDelete: Cascade)

  @@index([spaceId])
  @@map("shared_transactions")
}

// Cuentas (bancarias, efectivo, tarjetas de crédito)
model Account {
  id        String      @id @default(uuid())
  userId    String
  name      String
  type      AccountType
  balance   Decimal     @default(0) @db.Decimal(12, 2)
  color     String? // Color para UI
  icon      String? // Icono para UI
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // Relaciones
  profile      Profile       @relation(fields: [userId], references: [userId], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
  @@map("accounts")
}

enum AccountType {
  CASH
  CHECKING
  SAVINGS
  CREDIT_CARD
  INVESTMENT
  OTHER
}

// Categorías de transacciones
model Category {
  id        String          @id @default(uuid())
  userId    String
  name      String
  type      TransactionType
  color     String?
  icon      String?
  isDefault Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  // Relaciones
  profile      Profile       @relation(fields: [userId], references: [userId], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]

  @@index([userId])
  @@map("categories")
}

// Transacciones (ingresos y gastos)
model Transaction {
  id          String          @id @default(uuid())
  userId      String
  accountId   String
  categoryId  String?
  type        TransactionType
  amount      Decimal         @db.Decimal(12, 2)
  description String?
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Relaciones
  profile  Profile   @relation(fields: [userId], references: [userId], onDelete: Cascade)
  account  Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([accountId])
  @@index([categoryId])
  @@index([date])
  @@map("transactions")
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

// Presupuestos
model Budget {
  id         String       @id @default(uuid())
  userId     String
  categoryId String?
  amount     Decimal      @db.Decimal(12, 2)
  period     BudgetPeriod
  startDate  DateTime
  endDate    DateTime
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  // Relaciones
  profile  Profile   @relation(fields: [userId], references: [userId], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([categoryId])
  @@map("budgets")
}

enum BudgetPeriod {
  WEEKLY
  MONTHLY
  YEARLY
}

// Insights diarios del Coach IA (cache por día)
model CoachInsight {
  id        String   @id @default(uuid())
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())
  expiresAt DateTime

  profile Profile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId])
  @@map("coach_insights")
}

// Suscripciones de pago (Wompi)
model PaymentSource {
  id            String   @id @default(uuid())
  userId        String
  wompiSourceId String   @unique // ID de Wompi (número entero como string)
  type          String            // CARD, NEQUI, DAVIPLATA, BANCOLOMBIA_TRANSFER
  last4         String?           // Últimos 4 dígitos (solo tarjetas)
  brand         String?           // VISA, MASTERCARD, etc. (solo tarjetas)
  isDefault     Boolean  @default(true)
  createdAt     DateTime @default(now())

  profile       Profile        @relation(fields: [userId], references: [userId], onDelete: Cascade)
  subscriptions Subscription[]

  @@index([userId])
  @@map("payment_sources")
}

model Subscription {
  id              String             @id @default(uuid())
  userId          String
  paymentSourceId String?            // FK a PaymentSource (null en flujo redirect)
  wompiTxId       String             @unique // ID interno de la transacción Wompi
  wompiRef        String             @unique // Referencia legible (ej: LUKAPP-uuid)
  status          SubscriptionStatus @default(PENDING)
  billingCycle    BillingCycle       @default(MONTHLY)
  discountPercent Int                @default(0) // 10 = 10% descuento (anual)
  baseAmountCents Int?               // precio base antes del descuento
  amountCents     Int                // monto final cobrado por Wompi
  planStartsAt    DateTime
  planExpiresAt   DateTime
  autoRenew       Boolean            @default(true)
  nextBillingAt   DateTime?          // Fecha del próximo cobro automático
  cancelledAt     DateTime?          // Cuándo se canceló (si aplica)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  profile       Profile        @relation(fields: [userId], references: [userId], onDelete: Cascade)
  paymentSource PaymentSource? @relation(fields: [paymentSourceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([nextBillingAt]) // Para el cron de renovación
  @@map("subscriptions")
}

// Push notification subscriptions
model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  profile Profile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}
