{
  "name": "Lukapp-b",
  "version": "1.0.0",
  "description": "Backend API para Lukapp - Finanzas Personales",
  "main": "dist/index.js",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc && tsc-alias",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:validate": "tsx src/scripts/validate-db.ts",
    "db:studio": "prisma studio",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "finanzas",
    "personal",
    "api",
    "express",
    "prisma"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "@prisma/client": "6.19.2",
    "@supabase/supabase-js": "^2.90.1",
    "@types/multer": "^2.1.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-async-errors": "^3.1.1",
    "groq-sdk": "^1.1.1",
    "multer": "^2.1.1",
    "openai": "^6.31.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^20.19.30",
    "@types/web-push": "^3.6.4",
    "eslint": "^9",
    "prisma": "6.19.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
